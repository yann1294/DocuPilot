# Required: Clerk publishable key used by browser/client components.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# Required: Clerk secret key used by Next.js server/middleware.
CLERK_SECRET_KEY=sk_test_replace_me

# Required: deployed backend base URL (API Gateway URL), no trailing slash.
NEXT_PUBLIC_API_BASE_URL=https://example.execute-api.us-east-1.amazonaws.com
